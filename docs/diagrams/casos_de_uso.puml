@startuml
left to right direction
actor "Usuário" as User
actor "Modelo de Linguagem (IA)" as LLM

rectangle "App Finanças Pessoais com IA" {
  
  usecase "UC1: Registrar Receita" as UC1
  usecase "UC2: Registrar Despesa" as UC2
  usecase "UC3: Configurar Despesa Recorrente" as UC3
  usecase "UC4: Visualizar Saldo" as UC4
  usecase "UC5: Criar Orçamento Mensal" as UC5
  usecase "UC6: Visualizar Relatórios" as UC6
  usecase "UC7: Gerenciar Bancos" as UC7
  usecase "UC8: Associar Banco à Despesa" as UC8
  usecase "UC9: Gerenciar Metas Financeiras" as UC9
  usecase "UC10: Chat com IA Financeira" as UC10
  usecase "UC11: Classificação Inteligente" as UC11
  usecase "UC12: Previsões Financeiras" as UC12
  usecase "UC13: Exportar Dados" as UC13
  usecase "UC14: Gerenciar Categorias" as UC14
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC13
User --> UC14

UC10 --> LLM : consultas e análises
UC11 --> LLM : classificação de transações
UC12 --> LLM : geração de insights

UC3 .> UC2 : extends
UC8 .> UC2 : extends
UC11 .> UC1 : extends
UC11 .> UC2 : extends
UC6 .> UC12 : includes

note right of UC3
  * Diária
  * Semanal
  * Mensal
  * Anual
  * Personalizado
end note

note right of UC7
  * Cadastrar banco
  * Editar banco
  * Excluir banco
  * Listar bancos
end note

@enduml